---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';

const workProjects = projects.filter((p) => p.category === 'work');
const explorations = projects.filter((p) => p.category === 'exploration');

const testimonials = [
  {
    quote: "Explicit didn't just give us a brand — they gave us a story that made investors lean in and customers remember our name.",
    name: "Placeholder Name",
    role: "CEO, Startup Co",
    avatar: "",
    cardBg: "transparent",
    textColor: "#F5F5F5"
  },
  {
    quote: "Most agencies gave us mood boards. Explicit gave us a narrative that became our entire GTM strategy.",
    name: "Placeholder Name",
    role: "Founder, Product Co",
    avatar: "",
    cardBg: "transparent",
    textColor: "#F5F5F5"
  },
  {
    quote: "We went from 'another AI company' to the one people actually talked about. That's the Explicit difference.",
    name: "Placeholder Name",
    role: "Co-founder, AI Startup",
    avatar: "",
    cardBg: "transparent",
    textColor: "#F5F5F5"
  },
  {
    quote: "They made biohacking feel like culture, not science. Our community grew itself after that.",
    name: "Placeholder Name",
    role: "Founder, Wellness Brand",
    avatar: "",
    cardBg: "transparent",
    textColor: "#F5F5F5"
  }
];
---

<BaseLayout title="Explicit Studio — Creative Partners for Startups" showExplicitToggle={true}>

  <!-- Hero -->
  <section class="hero">
    <h1 class="hero__headline" data-explicit-swap="hero-headline">
      We build brands as ambitious as the founders behind them.
    </h1>
    <p class="hero__descriptor" data-explicit-swap="hero-descriptor">Creative partners for startups. Led by Srijan Mahajan.</p>
    <div class="hero__media">
      <video src="/images/projects/home-showreel-thumb.mp4" autoplay muted loop playsinline></video>
    </div>
  </section>

  <!-- Logo Bar -->
  <section class="logos-section">
    <p class="logos-section__text">
      Working with ambitious founders & adventure capitalists across AI, Web3 & D2C.
    </p>
    <div class="logos-grid">
      <img src="/images/logos/pause.png" alt="Pause" class="client-logo" />
      <img src="/images/logos/attis.png" alt="Attis" class="client-logo" />
      <img src="/images/logos/QAonC.svg" alt="QAonC" class="client-logo" />
      <img src="/images/logos/qb.png" alt="QB" class="client-logo" />
      <img src="/images/logos/originone.png" alt="Origin One" class="client-logo" />
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials-section reveal">
    <div class="testimonials-grid">
      {testimonials.map(t => (
        <div class="testimonial-card">
          <p class="testimonial-card__quote" style={`color: ${t.textColor};`}>"{t.quote}"</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">
              {t.avatar ? (
                <img src={t.avatar} alt={t.name} />
              ) : (
                <span>{t.name.charAt(0)}</span>
              )}
            </div>
            <div class="testimonial-card__info">
              <span class="testimonial-card__name" style={`color: ${t.textColor};`}>{t.name}</span>
              <span class="testimonial-card__role" style={`color: rgba(255,255,255,0.5);`}>{t.role}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- The Pitch -->
  <section class="problem-section reveal">
    <div class="problem-section__inner">
      <p class="problem-section__opening" data-explicit-swap="pitch-headline">
        130,000 startups launch every day. Most die of obscurity.
      </p>
      <div class="problem-section__body">
        <p data-explicit-swap="pitch-p1">Your product works, but product alone doesn't set you apart anymore. The cost of building is down to zero & attention is the most expensive resource in the world. Maybe that's why the startups winning now (think Anthropic, Stripe, Ramp, Anduril) are all investing in brand as seriously as they invest in engineering. Everyone else competes on price until they disappear. We're here to make sure that's not you.</p>
        <p data-explicit-swap="pitch-p2">Explicit is led by Srijan Mahajan, a founder, creative director & musician. He has played 1000+ concerts as a drummer for Parikrama. Then he built Pause; a mental health platform that broke its category and Attis; India's first & largest biohacking & longevity community. <br /><br />An ex-founder, he's sat where you're sitting — which is why Explicit is built to be as founder-friendly as possible. No agency layer. No six-month timeline. No scope creep. You work directly with Srijan to build your positioning, identity, website & content strategy — everything your startup needs to launch, in 6 weeks.</p>
      </div>
    </div>
  </section>

  <!-- CTA after pitch -->
  <section class="pitch-cta reveal">
    <a href="/contact" class="btn-primary pitch-cta__button">
      Get in touch <span class="arrow">&rarr;</span>
    </a>
  </section>

  <!-- Selected Work -->
  <section class="work-section reveal">
    <h2 class="work-section__title">We make things people like. We make people like things.</h2>
    <div class="home-work-grid">
      {workProjects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
    {explorations.length > 0 && (
      <h3 class="work-section__subtitle">Explorations</h3>
      <div class="home-work-grid">
        {explorations.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    )}
    <a href="/work" class="view-all-card">
      <span class="view-all-card__text">View all work &rarr;</span>
    </a>
  </section>

</BaseLayout>

<style>
  /* ===== Hero ===== */
  .hero {
    padding: 40px var(--section-padding-x) 40px;
  }

  .hero__descriptor {
    font-size: var(--text-h3);
    font-weight: 500;
    color: var(--color-text-secondary);
    margin-bottom: 20px;
  }

  .hero__headline {
    font-size: var(--text-hero);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text);
    max-width: none;
    margin-bottom: 12px;
  }

  .hero__media {
    width: 100%;
    margin-top: 40px;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .hero__media video {
    width: 100%;
    display: block;
  }

  /* ===== Logo Bar ===== */
  .logos-section {
    padding: 24px var(--section-padding-x) 24px;
  }

  .logos-section__text {
    font-size: var(--text-h3);
    font-weight: 500;
    color: var(--color-text-secondary);
    margin-bottom: 24px;
  }

  .logos-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 24px 0;
    width: 100%;
  }

  .client-logo {
    height: 36px;
    width: auto;
  }

  /* ===== Selected Work ===== */
  .work-section {
    padding: 60px var(--section-padding-x) var(--section-padding-y);
  }

  .work-section__title {
    font-size: var(--text-h2);
    font-weight: 500;
    margin-bottom: 48px;
  }

  .home-work-grid {
    display: flex;
    flex-direction: column;
    gap: clamp(24px, 4vw, 40px);
  }

  .work-section__subtitle {
    font-size: var(--text-h2);
    font-weight: 500;
    margin-top: 60px;
    margin-bottom: 48px;
  }

  .view-all-card {
    display: block;
    width: 100%;
    background-color: var(--color-accent);
    border-radius: var(--radius-md);
    padding: clamp(11px, 1.4vw, 20px);
    text-decoration: none;
    color: #FFFFFF;
    text-align: right;
    margin-top: clamp(24px, 3vw, 40px);
  }

  .view-all-card__text {
    font-size: var(--text-h3);
    font-weight: 500;
  }

  /* ===== The Problem ===== */
  .problem-section {
    padding: clamp(40px, 5vw, 60px) var(--section-padding-x);
    background: var(--color-bg);
  }

  .problem-section__inner {
    max-width: 800px;
  }

  .problem-section__opening {
    font-size: var(--text-h2);
    font-weight: 500;
    font-style: normal;
    line-height: 1.3;
    margin-bottom: 32px;
  }

  .problem-section__body p {
    font-size: var(--text-h3);
    font-weight: 400;
    line-height: 1.6;
    margin-bottom: 24px;
    color: var(--color-text);
  }

  .problem-section__body p:last-child {
    margin-bottom: 0;
  }

  .problem-section__body strong {
    font-weight: 700;
  }

  /* ===== Testimonials ===== */
  .testimonials-section {
    padding: clamp(40px, 5vw, 60px) var(--section-padding-x);
    background: var(--color-bg);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(16px, 2vw, 24px);
  }

  .testimonial-card {
    border-radius: var(--radius-md);
    padding: clamp(24px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 280px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .testimonial-card__quote {
    font-size: var(--text-body);
    font-weight: 400;
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .testimonial-card__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonial-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-card__avatar span {
    font-size: 1rem;
    font-weight: 500;
  }

  .testimonial-card__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testimonial-card__name {
    font-size: var(--text-small);
    font-weight: 500;
  }

  .testimonial-card__role {
    font-size: var(--text-tiny);
    font-weight: 400;
  }

  /* ===== Pitch CTA ===== */
  .pitch-cta {
    padding: 0 var(--section-padding-x) clamp(40px, 5vw, 60px);
    background: var(--color-bg);
  }

  .pitch-cta__button {
    display: inline-flex;
  }

  /* ===== Responsive ===== */
  @media (max-width: 767px) {
    .hero {
      padding: 32px var(--section-padding-x) 32px;
    }

    .hero__headline {
      margin-bottom: 8px;
    }

    .hero__media {
      margin-top: 32px;
    }

    .logos-section {
      padding: 32px var(--section-padding-x) 32px;
    }

    .logos-grid {
      justify-content: center;
      gap: 20px 32px;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .client-logo {
      height: 28px;
    }
  }
</style>

<script>
  // Scroll reveal
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.reveal').forEach((el) => {
    observer.observe(el);
  });

  // Explicit mode toggle
  const explicitContent: Record<string, { normal: string; explicit: string; html?: boolean }> = {
    'hero-headline': {
      normal: 'We build brands as ambitious as the founders behind them.',
      explicit: 'Explicit helps you make more money and get more attention.',
    },
    'hero-descriptor': {
      normal: 'Creative partners for startups. Led by Srijan Mahajan.',
      explicit: 'Brand, advertising & GTM for startups that refuse to compete on price.',
    },
    'sidebar-descriptor': {
      normal: 'Creative partners for startups.<br>Led by Srijan Mahajan.',
      explicit: 'Brand, advertising & GTM for startups that refuse to compete on price.',
      html: true,
    },
    'mobile-descriptor': {
      normal: 'Creative partners for startups.<br>Led by Srijan Mahajan.',
      explicit: 'Brand, advertising & GTM for startups that refuse to compete on price.',
      html: true,
    },
    'pitch-headline': {
      normal: '130,000 startups launch every day. Most die of obscurity.',
      explicit: "Creativity has been my business for 15 years.",
    },
    'pitch-p1': {
      normal: "Your product works, but product alone doesn't set you apart anymore. The cost of building is down to zero & attention is the most expensive resource in the world. Maybe that's why the startups winning now (think Anthropic, Stripe, Ramp, Anduril) are all investing in brand as seriously as they invest in engineering. Everyone else competes on price until they disappear. We're here to make sure that's not you.",
      explicit: "Creativity has been my business for 15 years. I've made money from it as a musician, in advertising, in film, and by building two startups of my own. I'm not a strategist who's never shipped anything, but a founder who spent his own money, and learned what actually works. I help startups with brand, positioning, advertising & content to get your story out in the most honest, explicit way possible.",
    },
    'pitch-p2': {
      normal: "Explicit is led by Srijan Mahajan, a founder, creative director & musician. He has played 1000+ concerts as a drummer for Parikrama. Then he built Pause; a mental health platform that broke its category and Attis; India's first & largest biohacking & longevity community.<br><br>An ex-founder, he's sat where you're sitting — which is why Explicit is built to be as founder-friendly as possible. No agency layer. No six-month timeline. No scope creep. You work directly with Srijan to build your positioning, identity, website & content strategy — everything your startup needs to launch, in 6 weeks.",
      explicit: "Most of you won't understand why this page reads the way it does. That's fine — it just means we're not ready to work together yet. If you'd like to see me talk about brand building in a more polished way, flip the toggle back.<br><br>But I'd rather be honest about what this is really about: helping you make more money. If you believe creativity is a business advantage and want a creative partner who actually gets that, we should talk.",
      html: true,
    },
    'cta-subline': {
      normal: "You've made something the world needs.",
      explicit: '',
    },
    'cta-headline': {
      normal: 'Make it Explicit.',
      explicit: 'Make more money.',
    },
  };

  function setExplicitMode(on: boolean) {
    for (const [key, content] of Object.entries(explicitContent)) {
      const el = document.querySelector(`[data-explicit-swap="${key}"]`);
      if (!el) continue;
      const text = on ? content.explicit : content.normal;
      if (content.html) {
        el.innerHTML = text;
      } else {
        el.textContent = text;
      }
    }

    // Sync both toggles
    const desktop = document.getElementById('explicit-toggle-desktop') as HTMLInputElement | null;
    const mobile = document.getElementById('explicit-toggle-mobile') as HTMLInputElement | null;
    if (desktop) desktop.checked = on;
    if (mobile) mobile.checked = on;
  }

  document.getElementById('explicit-toggle-desktop')?.addEventListener('change', (e) => {
    setExplicitMode((e.target as HTMLInputElement).checked);
  });

  document.getElementById('explicit-toggle-mobile')?.addEventListener('change', (e) => {
    setExplicitMode((e.target as HTMLInputElement).checked);
  });
</script>
